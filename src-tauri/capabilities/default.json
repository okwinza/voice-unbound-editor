{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the Voice Unbound Editor main window — full fs access scoped broadly so modders can point the picker at any Skyrim mod folder, dialog for folder picking, shell for Reveal-in-Explorer.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-watch",
    "fs:scope-home-recursive",
    "fs:scope-appdata-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "explorer",
          "cmd": "explorer",
          "args": true
        }
      ]
    }
  ]
}
